# Meta WhatsApp Cloud API – required for sending order notifications
# Get these from: https://developers.facebook.com/apps → Your App → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
# Recipient(s): phone number with country code, no + (e.g. 962771234567)
WHATSAPP_RECIPIENT_PHONE=962771234567
# Optional second recipient
# WHATSAPP_RECIPIENT_PHONE_2=962779876543
