{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "api/orders.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/", "dest": "/api/index.js" },
    {
      "src": "/api/orders",
      "methods": ["POST"],
      "dest": "/api/orders.js"
    }
  ]
}
